# Crash logs
crash.log
crash.log.*

# Exclude all .tfvars files, which are likely to contain sentitive data,
# such as password, private keys, and other secrets.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually local customizations
override.tf
override.tf.json
*_override.tf
*_override.tf.json

**/.DS_Store
.DS_Store
